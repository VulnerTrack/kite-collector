{
  "schema_version": "1.0.0",
  "presets": [
    {
      "id": "quick_scan",
      "primary": true,
      "title": "Quick local scan (offline, no backend)",
      "description": "Scan this machine for assets, software, and misconfigurations. Results stored locally in SQLite.",
      "context": {
        "discovery.agent.enabled": true,
        "discovery.agent.collect_software": true,
        "discovery.network.enabled": false,
        "audit.enabled": true,
        "audit.profile": "standard",
        "posture.enabled": true,
        "endpoint.primary.address": "",
        "streaming.interval": "",
        "output_format": "table"
      },
      "skip_groups": [
        "endpoints",
        "streaming",
        "business_context"
      ],
      "post_actions": [
        "run_first_scan"
      ]
    },
    {
      "id": "network_inventory",
      "primary": false,
      "title": "Network asset inventory (scan a CIDR range)",
      "description": "Discover all hosts on your network via TCP scanning + local agent. Offline, no backend required.",
      "context": {
        "discovery.agent.enabled": true,
        "discovery.network.enabled": true,
        "audit.enabled": true,
        "audit.profile": "standard",
        "posture.enabled": true,
        "endpoint.primary.address": ""
      },
      "skip_groups": [
        "endpoints",
        "streaming",
        "business_context"
      ],
      "post_actions": [
        "run_first_scan"
      ]
    },
    {
      "id": "connect_otel",
      "primary": true,
      "title": "Stream findings to OpenTelemetry / VulnerTrack backend",
      "description": "Configure the agent to push asset events, findings, and metrics to an OTEL Collector or VulnerTrack server over mTLS.",
      "context": {
        "discovery.agent.enabled": true,
        "discovery.agent.collect_software": true,
        "audit.enabled": true,
        "posture.enabled": true
      },
      "skip_groups": [],
      "post_actions": [
        "enroll_if_token_provided"
      ]
    },
    {
      "id": "systemd_service",
      "primary": true,
      "title": "Install as systemd service (continuous monitoring)",
      "description": "Configure + install kite-collector as a systemd unit that runs scans on a recurring schedule and streams results to a backend.",
      "context": {
        "discovery.agent.enabled": true,
        "discovery.agent.collect_software": true,
        "audit.enabled": true,
        "audit.profile": "standard",
        "posture.enabled": true,
        "data_dir": "/var/lib/kite-collector"
      },
      "skip_groups": [],
      "post_actions": [
        "generate_systemd_unit",
        "enroll_if_token_provided"
      ]
    },
    {
      "id": "docker_compose",
      "primary": false,
      "title": "Generate docker-compose deployment",
      "description": "Create a docker-compose.yml with kite-collector + OTEL Collector + ClickHouse for a self-contained deployment.",
      "context": {
        "discovery.agent.enabled": true,
        "discovery.docker.enabled": true,
        "audit.enabled": true,
        "posture.enabled": true,
        "streaming.otlp.endpoint": "http://otelcol:4318"
      },
      "skip_groups": [],
      "post_actions": [
        "generate_docker_compose"
      ]
    },
    {
      "id": "cloud_inventory",
      "primary": false,
      "title": "Cloud + VPS asset inventory (AWS, GCP, Azure, Hetzner, ...)",
      "description": "Discover assets across cloud providers and VPS hosting platforms. Requires API tokens in environment variables.",
      "context": {
        "discovery.agent.enabled": true,
        "discovery.agent.collect_software": false,
        "discovery.network.enabled": false,
        "audit.enabled": false,
        "posture.enabled": false
      },
      "skip_groups": [
        "audit",
        "safety"
      ],
      "post_actions": [
        "run_first_scan"
      ]
    },
    {
      "id": "compliance_audit",
      "primary": false,
      "title": "CIS compliance audit (SSH, firewall, kernel, permissions)",
      "description": "Run a full configuration audit against CIS benchmarks with CWE/CAPEC posture analysis. No network scanning.",
      "context": {
        "discovery.agent.enabled": true,
        "discovery.agent.collect_software": true,
        "discovery.network.enabled": false,
        "audit.enabled": true,
        "audit.profile": "full",
        "posture.enabled": true,
        "endpoint.primary.address": ""
      },
      "skip_groups": [
        "endpoints",
        "streaming"
      ],
      "post_actions": [
        "run_first_scan"
      ]
    },
    {
      "id": "mssp_multi_tenant",
      "primary": false,
      "title": "MSSP multi-tenant agent (report to client + fleet manager)",
      "description": "Configure an agent that reports assets to a client's backend and heartbeats to the MSSP's fleet manager. Requires enrollment tokens for both endpoints.",
      "context": {
        "discovery.agent.enabled": true,
        "discovery.agent.collect_software": true,
        "audit.enabled": true,
        "audit.profile": "standard",
        "posture.enabled": true
      },
      "skip_groups": [],
      "post_actions": [
        "configure_secondary_endpoint",
        "enroll_if_token_provided"
      ]
    },
    {
      "id": "tunnel_to_saas",
      "primary": true,
      "title": "Connect via tunnel (behind firewall/NAT)",
      "description": "Set up a reverse tunnel to reach the VulnerTrack backend from a restricted network.",
      "context": {
        "connectivity.tunnel.enabled": true,
        "discovery.agent.enabled": true,
        "audit.enabled": true,
        "streaming.otlp.protocol": "http"
      },
      "skip_groups": [
        "business_context"
      ],
      "post_actions": [
        "start_tunnel",
        "enroll_if_token_provided",
        "run_first_scan"
      ]
    },
    {
      "id": "custom",
      "primary": true,
      "title": "Custom configuration (full wizard)",
      "description": "Walk through every option. Use this when none of the presets match your use case.",
      "context": {},
      "skip_groups": [],
      "post_actions": []
    }
  ],
  "groups": [
    {
      "id": "environment",
      "title": "Environment & Basics",
      "nodes": [
        {
          "id": "log_level",
          "type": "select",
          "prompt": "Log verbosity level",
          "options": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "depends_on": [],
          "default_rule": "'info'",
          "required": true
        },
        {
          "id": "output_format",
          "type": "select",
          "prompt": "Default output format",
          "options": [
            "json",
            "table",
            "csv"
          ],
          "depends_on": [],
          "default_rule": "'json'",
          "required": true
        },
        {
          "id": "data_dir",
          "type": "input",
          "prompt": "Local data directory (SQLite storage)",
          "depends_on": [],
          "default_rule": "'./data'",
          "required": true
        },
        {
          "id": "stale_threshold",
          "type": "input",
          "prompt": "Stale asset threshold (e.g., 168h = 7 days)",
          "depends_on": [],
          "default_rule": "'168h'",
          "required": true
        }
      ]
    },
    {
      "id": "discovery",
      "title": "Discovery Sources",
      "nodes": [
        {
          "id": "discovery.agent.enabled",
          "type": "confirm",
          "prompt": "Enable local agent discovery (hostname, OS, software)?",
          "depends_on": [],
          "default_rule": "true",
          "required": true
        },
        {
          "id": "discovery.agent.collect_software",
          "type": "confirm",
          "prompt": "Collect installed software inventory?",
          "depends_on": [
            "discovery.agent.enabled"
          ],
          "default_rule": "ctx['discovery.agent.enabled'] == true",
          "required": true
        },
        {
          "id": "discovery.docker.enabled",
          "type": "confirm",
          "prompt": "Enable Docker/Podman container discovery?",
          "depends_on": [],
          "default_rule": "has(ctx.autodiscovery) && ctx.autodiscovery.exists(s, s == 'docker')",
          "required": true,
          "preflight_validate": "docker:socket:probe"
        },
        {
          "id": "discovery.docker.host",
          "type": "input",
          "prompt": "Docker socket path or TCP endpoint",
          "depends_on": [
            "discovery.docker.enabled"
          ],
          "default_rule": "ctx['discovery.docker.enabled'] ? 'unix:///var/run/docker.sock' : ''",
          "required": false,
          "skip_when": "ctx['discovery.docker.enabled'] == false"
        },
        {
          "id": "discovery.network.enabled",
          "type": "confirm",
          "prompt": "Enable TCP network scanning?",
          "depends_on": [],
          "default_rule": "false",
          "required": true
        },
        {
          "id": "discovery.network.scope",
          "type": "input",
          "prompt": "CIDR scopes to scan (comma-separated, e.g., 192.168.1.0/24,10.0.0.0/16)",
          "depends_on": [
            "discovery.network.enabled"
          ],
          "default_rule": "''",
          "required": true,
          "skip_when": "ctx['discovery.network.enabled'] == false",
          "preflight_validate": "network:cidr:parse"
        },
        {
          "id": "discovery.network.tcp_ports",
          "type": "input",
          "prompt": "TCP ports to scan (comma-separated)",
          "depends_on": [
            "discovery.network.enabled"
          ],
          "default_rule": "'22,80,443,3389,8080,8443'",
          "required": true,
          "skip_when": "ctx['discovery.network.enabled'] == false"
        },
        {
          "id": "discovery.vps_providers",
          "type": "multiselect",
          "prompt": "Enable VPS provider connectors",
          "options": [
            "hetzner",
            "digitalocean",
            "vultr",
            "linode",
            "scaleway",
            "ovhcloud",
            "upcloud",
            "kamatera",
            "hostinger"
          ],
          "depends_on": [],
          "default_rule": "[]",
          "required": false,
          "preflight_validate": "vps:env:check"
        },
        {
          "id": "discovery.paas_platforms",
          "type": "multiselect",
          "prompt": "Enable PaaS platform connectors",
          "options": [
            "heroku",
            "render",
            "flyio",
            "railway",
            "vercel",
            "coolify",
            "caprover"
          ],
          "depends_on": [],
          "default_rule": "[]",
          "required": false
        },
        {
          "id": "discovery.mdm_provider",
          "type": "select",
          "prompt": "MDM connector (devices marked as managed)",
          "options": [
            "none",
            "intune",
            "jamf",
            "sccm"
          ],
          "depends_on": [],
          "default_rule": "'none'",
          "required": true,
          "preflight_validate": "mdm:env:check"
        },
        {
          "id": "discovery.cmdb_provider",
          "type": "select",
          "prompt": "CMDB connector (CIs marked as authorized)",
          "options": [
            "none",
            "netbox",
            "servicenow"
          ],
          "depends_on": [],
          "default_rule": "'none'",
          "required": true,
          "preflight_validate": "cmdb:env:check"
        },
        {
          "id": "discovery.ldap.enabled",
          "type": "confirm",
          "prompt": "Enable Active Directory / LDAP discovery (RFC-0121)?",
          "depends_on": [],
          "default_rule": "false",
          "required": true
        },
        {
          "id": "discovery.ldap.tls_mode",
          "type": "select",
          "prompt": "LDAP TLS mode (ldaps=636/SSL, starttls=389+upgrade, none=plaintext)",
          "options": [
            "ldaps",
            "starttls",
            "none"
          ],
          "depends_on": [
            "discovery.ldap.enabled"
          ],
          "default_rule": "'ldaps'",
          "required": true,
          "skip_when": "ctx['discovery.ldap.enabled'] == false",
          "preflight_validate": "ldap:tls_mode:valid"
        },
        {
          "id": "discovery.ldap.tls_ca_file",
          "type": "input",
          "prompt": "Path to CA bundle pinning the LDAP server cert (blank = system store)",
          "depends_on": [
            "discovery.ldap.enabled",
            "discovery.ldap.tls_mode"
          ],
          "default_rule": "''",
          "required": false,
          "skip_when": "ctx['discovery.ldap.enabled'] == false || ctx['discovery.ldap.tls_mode'] == 'none'",
          "preflight_validate": "file:exists"
        },
        {
          "id": "discovery.ldap.base_dn",
          "type": "input",
          "prompt": "Search base DN (e.g., DC=corp,DC=acme,DC=com)",
          "depends_on": [
            "discovery.ldap.enabled"
          ],
          "default_rule": "''",
          "required": true,
          "skip_when": "ctx['discovery.ldap.enabled'] == false",
          "preflight_validate": "ldap:base_dn:syntax"
        },
        {
          "id": "discovery.ldap.bind_dn",
          "type": "input",
          "prompt": "Bind DN for the read-only service account (e.g., CN=svc-kite,OU=ServiceAccounts,DC=corp,DC=acme,DC=com)",
          "depends_on": [
            "discovery.ldap.enabled"
          ],
          "default_rule": "''",
          "required": true,
          "skip_when": "ctx['discovery.ldap.enabled'] == false"
        },
        {
          "id": "discovery.ldap.bind_password_env",
          "type": "input",
          "prompt": "Environment variable holding the bind password",
          "depends_on": [
            "discovery.ldap.enabled"
          ],
          "default_rule": "'KITE_LDAP_BIND_PASSWORD'",
          "required": true,
          "skip_when": "ctx['discovery.ldap.enabled'] == false",
          "preflight_validate": "ldap:bind:env"
        },
        {
          "id": "discovery.ldap.domain_controllers",
          "type": "input",
          "prompt": "Domain controllers (comma-separated host or host:port; e.g., dc1.corp.acme.com,dc2.corp.acme.com)",
          "depends_on": [
            "discovery.ldap.enabled",
            "discovery.ldap.tls_mode"
          ],
          "default_rule": "''",
          "required": true,
          "skip_when": "ctx['discovery.ldap.enabled'] == false",
          "preflight_validate": "ldap:dc:connect"
        },
        {
          "id": "discovery.ldap.stale_threshold_days",
          "type": "input",
          "prompt": "Stale-account threshold in days (CWE-1002 trigger)",
          "depends_on": [
            "discovery.ldap.enabled"
          ],
          "default_rule": "'90'",
          "required": false,
          "skip_when": "ctx['discovery.ldap.enabled'] == false"
        },
        {
          "id": "discovery.sources.entra.enabled",
          "type": "confirm",
          "prompt": "Enable Microsoft Entra ID identity discovery (RFC-0121)?",
          "depends_on": [
            "discovery.ldap.enabled"
          ],
          "default_rule": "false",
          "required": true
        },
        {
          "id": "discovery.sources.entra.tenant_id",
          "type": "input",
          "prompt": "Entra tenant (Directory) ID — GUID from Azure Portal → Entra ID → Overview",
          "depends_on": [
            "discovery.sources.entra.enabled"
          ],
          "default_rule": "''",
          "required": true,
          "skip_when": "ctx['discovery.sources.entra.enabled'] == false",
          "preflight_validate": "entra:tenant_id:guid"
        },
        {
          "id": "discovery.sources.entra.client_id",
          "type": "input",
          "prompt": "Entra application (client) ID — GUID from Azure Portal → App registrations → <app> → Overview",
          "depends_on": [
            "discovery.sources.entra.enabled"
          ],
          "default_rule": "''",
          "required": true,
          "skip_when": "ctx['discovery.sources.entra.enabled'] == false",
          "preflight_validate": "entra:client_id:guid"
        },
        {
          "id": "discovery.sources.entra.client_secret_env",
          "type": "input",
          "prompt": "Environment variable holding the Entra client_secret value",
          "depends_on": [
            "discovery.sources.entra.enabled"
          ],
          "default_rule": "'ENTRA_CLIENT_SECRET'",
          "required": true,
          "skip_when": "ctx['discovery.sources.entra.enabled'] == false",
          "preflight_validate": "entra:secret:env"
        },
        {
          "id": "discovery.sources.entra.stale_account_days",
          "type": "input",
          "prompt": "Stale-account threshold in days (ENTRA-001 trigger)",
          "depends_on": [
            "discovery.sources.entra.enabled"
          ],
          "default_rule": "'90'",
          "required": false,
          "skip_when": "ctx['discovery.sources.entra.enabled'] == false"
        }
      ]
    },
    {
      "id": "audit",
      "title": "Configuration Audit",
      "nodes": [
        {
          "id": "audit.enabled",
          "type": "confirm",
          "prompt": "Enable configuration audit (SSH, firewall, permissions, kernel)?",
          "depends_on": [],
          "default_rule": "true",
          "required": true
        },
        {
          "id": "audit.profile",
          "type": "select",
          "prompt": "Audit profile",
          "options": [
            "minimal",
            "standard",
            "full"
          ],
          "depends_on": [
            "audit.enabled"
          ],
          "default_rule": "ctx['audit.enabled'] ? 'standard' : 'minimal'",
          "required": true,
          "skip_when": "ctx['audit.enabled'] == false"
        },
        {
          "id": "posture.enabled",
          "type": "confirm",
          "prompt": "Enable posture analysis (CWE \u2192 CAPEC attack pattern mapping)?",
          "depends_on": [
            "audit.enabled"
          ],
          "default_rule": "ctx['audit.enabled']",
          "required": true
        }
      ]
    },
    {
      "id": "business_context",
      "title": "Business Context & Classification",
      "nodes": [
        {
          "id": "business.environment",
          "type": "select",
          "prompt": "What environment does this host serve?",
          "options": [
            "production",
            "staging",
            "development",
            "lab",
            "dmz"
          ],
          "depends_on": [],
          "default_rule": "'production'",
          "required": true
        },
        {
          "id": "business.owner",
          "type": "input",
          "prompt": "Asset owner (team or person responsible)",
          "depends_on": [],
          "default_rule": "''",
          "required": false
        },
        {
          "id": "business.criticality",
          "type": "select",
          "prompt": "Business criticality of assets on this host",
          "options": [
            "critical",
            "high",
            "medium",
            "low"
          ],
          "depends_on": [
            "business.environment"
          ],
          "default_rule": "ctx['business.environment'] == 'production' ? 'high' : 'low'",
          "required": true
        },
        {
          "id": "business.process",
          "type": "input",
          "prompt": "Business process this asset supports (e.g., payment-processing, customer-portal, ci-cd)",
          "depends_on": [],
          "default_rule": "''",
          "required": false
        },
        {
          "id": "business.data_classification",
          "type": "select",
          "prompt": "Data classification for assets on this host",
          "options": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ],
          "depends_on": [],
          "default_rule": "'internal'",
          "required": true
        },
        {
          "id": "business.compliance_frameworks",
          "type": "multiselect",
          "prompt": "Applicable compliance frameworks",
          "options": [
            "none",
            "soc2",
            "iso27001",
            "pci-dss",
            "hipaa",
            "gdpr",
            "nist-csf",
            "cis"
          ],
          "depends_on": [],
          "default_rule": "['none']",
          "required": false
        },
        {
          "id": "business.tags",
          "type": "input",
          "prompt": "Custom tags (comma-separated key=value pairs, e.g., team=platform,region=eu-west-1)",
          "depends_on": [],
          "default_rule": "''",
          "required": false
        },
        {
          "id": "classification.allowlist_file",
          "type": "input",
          "prompt": "Path to authorized assets allowlist YAML (blank = skip authorization classification)",
          "depends_on": [],
          "default_rule": "''",
          "required": false,
          "preflight_validate": "file:exists"
        },
        {
          "id": "classification.match_fields",
          "type": "multiselect",
          "prompt": "Fields to match against allowlist",
          "options": [
            "hostname",
            "mac_address",
            "ip_address",
            "cloud_instance_id"
          ],
          "depends_on": [
            "classification.allowlist_file"
          ],
          "default_rule": "ctx['classification.allowlist_file'] != '' ? ['hostname', 'mac_address'] : []",
          "required": false,
          "skip_when": "ctx['classification.allowlist_file'] == ''"
        },
        {
          "id": "classification.managed_controls",
          "type": "input",
          "prompt": "Required controls for 'managed' status (comma-separated, blank = opt-in)",
          "depends_on": [],
          "default_rule": "''",
          "required": false
        }
      ]
    },
    {
      "id": "endpoints",
      "title": "Backend Endpoints (RFC-0072)",
      "nodes": [
        {
          "id": "endpoint.primary.address",
          "type": "input",
          "prompt": "Primary backend endpoint (e.g., ingest.vulnertrack.example.com:443)",
          "depends_on": [],
          "default_rule": "has(ctx.autodiscovery) && ctx.autodiscovery.exists(s, s == 'otel_collector') ? 'localhost:4318' : ''",
          "required": false,
          "preflight_validate": "endpoint:tls:connect"
        },
        {
          "id": "endpoint.primary.enrollment_token",
          "type": "password",
          "prompt": "Enrollment token for primary endpoint (leave blank to skip enrollment)",
          "depends_on": [
            "endpoint.primary.address"
          ],
          "default_rule": "''",
          "required": false,
          "skip_when": "ctx['endpoint.primary.address'] == ''",
          "preflight_validate": "endpoint:enroll"
        },
        {
          "id": "endpoint.primary.encryption",
          "type": "confirm",
          "prompt": "Enable JWE payload encryption for primary endpoint?",
          "depends_on": [
            "endpoint.primary.address"
          ],
          "default_rule": "ctx['endpoint.primary.address'] != ''",
          "required": true,
          "skip_when": "ctx['endpoint.primary.address'] == ''"
        }
      ]
    },
    {
      "id": "connectivity",
      "title": "Connectivity & Tunneling (RFC-0083)",
      "nodes": [
        {
          "id": "connectivity.backend_reachable",
          "type": "confirm",
          "prompt": "Can this agent reach the backend endpoint directly?",
          "depends_on": [
            "endpoint.primary.address"
          ],
          "default_rule": "true",
          "required": true,
          "skip_when": "ctx['endpoint.primary.address'] == ''",
          "preflight_validate": "endpoint:tls:connect"
        },
        {
          "id": "connectivity.tunnel.enabled",
          "type": "confirm",
          "prompt": "Set up a tunnel to reach the backend?",
          "depends_on": [
            "connectivity.backend_reachable"
          ],
          "default_rule": "'connectivity.backend_reachable' in ctx && ctx['connectivity.backend_reachable'] == false",
          "required": true,
          "skip_when": "'connectivity.backend_reachable' in ctx && ctx['connectivity.backend_reachable'] == true"
        },
        {
          "id": "connectivity.tunnel.provider",
          "type": "select",
          "prompt": "Which tunnel tool is installed?",
          "options": [
            "ngrok",
            "cloudflared",
            "bore",
            "tailscale",
            "frp",
            "rathole"
          ],
          "depends_on": [
            "connectivity.tunnel.enabled"
          ],
          "default_rule": "has(ctx.autodiscovery) && ctx.autodiscovery.exists(s, s == 'ngrok') ? 'ngrok' : has(ctx.autodiscovery) && ctx.autodiscovery.exists(s, s == 'cloudflared') ? 'cloudflared' : 'ngrok'",
          "required": true,
          "skip_when": "!('connectivity.tunnel.enabled' in ctx) || ctx['connectivity.tunnel.enabled'] == false",
          "preflight_validate": "tunnel:binary:available"
        },
        {
          "id": "connectivity.tunnel.target",
          "type": "input",
          "prompt": "Backend address to tunnel to:",
          "depends_on": [
            "connectivity.tunnel.enabled",
            "endpoint.primary.address"
          ],
          "default_rule": "ctx['endpoint.primary.address']",
          "required": true,
          "skip_when": "!('connectivity.tunnel.enabled' in ctx) || ctx['connectivity.tunnel.enabled'] == false",
          "preflight_validate": "tunnel:port:free"
        },
        {
          "id": "connectivity.tunnel.auth_token_env",
          "type": "input",
          "prompt": "Env var for auth token (leave empty if none):",
          "depends_on": [
            "connectivity.tunnel.enabled"
          ],
          "default_rule": "ctx['connectivity.tunnel.provider'] == 'ngrok' ? 'KITE_TUNNEL_AUTH_TOKEN' : ctx['connectivity.tunnel.provider'] == 'frp' ? 'KITE_TUNNEL_AUTH_TOKEN' : ''",
          "required": false,
          "skip_when": "!('connectivity.tunnel.enabled' in ctx) || ctx['connectivity.tunnel.enabled'] == false",
          "preflight_validate": "tunnel:auth:valid"
        }
      ]
    },
    {
      "id": "streaming",
      "title": "Streaming & Telemetry (RFC-0073)",
      "nodes": [
        {
          "id": "streaming.interval",
          "type": "input",
          "prompt": "Streaming scan interval (e.g., 6h, 1h, 30m)",
          "depends_on": [
            "endpoint.primary.address"
          ],
          "default_rule": "ctx['endpoint.primary.address'] != '' ? '6h' : ''",
          "required": false,
          "skip_when": "ctx['endpoint.primary.address'] == ''"
        },
        {
          "id": "streaming.otlp.endpoint",
          "type": "input",
          "prompt": "OTEL Collector endpoint for telemetry",
          "depends_on": [
            "endpoint.primary.address"
          ],
          "default_rule": "has(ctx.autodiscovery) && ctx.autodiscovery.exists(s, s == 'otel_collector') ? 'http://localhost:4318' : ctx['endpoint.primary.address']",
          "required": false,
          "skip_when": "ctx['endpoint.primary.address'] == ''",
          "preflight_validate": "otel:health:check"
        }
      ]
    },
    {
      "id": "safety",
      "title": "Safety & Limits",
      "nodes": [
        {
          "id": "safety.scan_deadline",
          "type": "input",
          "prompt": "Maximum scan duration before timeout",
          "depends_on": [],
          "default_rule": "'30m'",
          "required": true
        },
        {
          "id": "safety.circuit_breaker.failure_threshold",
          "type": "input",
          "prompt": "Circuit breaker: consecutive failures before tripping",
          "depends_on": [],
          "default_rule": "'3'",
          "required": true
        }
      ]
    }
  ]
}
